{
  "uid": "smartqueue-serving",
  "title": "SmartQueue - Serving Performance",
  "tags": [
    "smartqueue"
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "version": 2,
  "timezone": "browser",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 100,
      "title": "--- Model Behavior ---",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "options": { "mode": "markdown", "content": "## Model Output Monitoring" }
    },
    {
      "id": 6,
      "title": "Request Rate (/queue)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 2 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0 },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{handler=\"/queue\"}[1m]))",
          "legendFormat": "requests/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Error Rate (/queue)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 2 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.02 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{handler=\"/queue\",status=~\"4..|5..\"}[5m])) / sum(rate(http_requests_total{handler=\"/queue\"}[5m]))",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Latency (/queue) - Avg & p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 2 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1200 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "1000 * rate(http_request_duration_seconds_sum{handler=\"/queue\"}[1m]) / rate(http_request_duration_seconds_count{handler=\"/queue\"}[1m])",
          "legendFormat": "avg latency",
          "refId": "A"
        },
        {
          "expr": "1000 * histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{handler=\"/queue\"}[1m]))",
          "legendFormat": "p95 latency",
          "refId": "B"
        }
      ]
    },
    {
      "id": 9,
      "title": "Avg Prediction Score",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "decimals": 3
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum(rate(prediction_score_sum[5m])) / sum(rate(prediction_score_count[5m]))",
          "legendFormat": "avg score",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Prediction Score Distribution",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "calculate": false,
        "yAxis": { "unit": "short" },
        "color": { "scheme": "Oranges" },
        "tooltip": { "show": true }
      },
      "targets": [
        {
          "expr": "sum(rate(prediction_score_bucket[5m])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Invalid Predictions & Bad Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "rate(prediction_invalid_total[5m])",
          "legendFormat": "invalid scores/s",
          "refId": "A"
        },
        {
          "expr": "rate(invalid_request_total[5m])",
          "legendFormat": "bad requests/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 12,
      "title": "Active Sessions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "smartqueue_active_sessions",
          "legendFormat": "sessions",
          "refId": "A"
        }
      ]
    },
    {
      "id": 18,
      "title": "Feedback: Reranks & Skips",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum(rate(smartqueue_rerank_total[5m]))",
          "legendFormat": "reranks/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(smartqueue_feedback_skips_total[5m]))",
          "legendFormat": "skips/s",
          "refId": "B"
        },
        {
          "expr": "sum(rate(smartqueue_feedback_completions_total[5m]))",
          "legendFormat": "completions/s",
          "refId": "C"
        }
      ]
    },
    {
      "id": 19,
      "title": "Feedback: Avg Songs Kept in Top Positions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.6 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "sum(rate(smartqueue_feedback_songs_kept_sum[5m])) / sum(rate(smartqueue_feedback_songs_kept_count[5m]))",
          "legendFormat": "kept ratio",
          "refId": "A"
        }
      ]
    },
    {
      "id": 101,
      "title": "--- Infrastructure ---",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 22 },
      "options": { "mode": "markdown", "content": "## Container & Scaling Metrics" }
    },
    {
      "id": 1,
      "title": "Container CPU Usage - Serving Pods",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=~\"smartqueue.*\", container!=\"\", container!=\"POD\"}[5m]) * 100",
          "legendFormat": "{{namespace}}/{{pod}}/{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Container Memory Usage - Serving Pods",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 536870912 },
              { "color": "red", "value": 1073741824 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{namespace=~\"smartqueue.*\", container!=\"\", container!=\"POD\"}",
          "legendFormat": "{{namespace}}/{{pod}}/{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "HPA Replicas",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=~\"smartqueue.*\"}",
          "legendFormat": "Current - {{horizontalpodautoscaler}}",
          "refId": "A"
        },
        {
          "expr": "kube_horizontalpodautoscaler_spec_min_replicas{namespace=~\"smartqueue.*\"}",
          "legendFormat": "Min - {{horizontalpodautoscaler}}",
          "refId": "B"
        },
        {
          "expr": "kube_horizontalpodautoscaler_spec_max_replicas{namespace=~\"smartqueue.*\"}",
          "legendFormat": "Max - {{horizontalpodautoscaler}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "title": "HPA CPU Target vs Actual",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_spec_target_metric{namespace=~\"smartqueue.*\", metric_name=\"cpu\"}",
          "legendFormat": "Target CPU% - {{horizontalpodautoscaler}}",
          "refId": "A"
        },
        {
          "expr": "kube_horizontalpodautoscaler_status_current_metrics_average_utilization{namespace=~\"smartqueue.*\", metric_name=\"cpu\"}",
          "legendFormat": "Actual CPU% - {{horizontalpodautoscaler}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "Pods by Namespace",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "count by(namespace) (kube_pod_status_phase{phase=\"Running\", namespace=~\"smartqueue.*\"})",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": { "list": [] }
}
