# DO NOT commit real secrets to Git
# Use scripts/create-secrets.sh to create the actual secret
# This file is a template showing the required fields

apiVersion: v1
kind: Secret
metadata:
  name: postgres-secret
  namespace: smartqueue-prod
type: Opaque
stringData:
  POSTGRES_USER: "mlflow"
  POSTGRES_PASSWORD: "CHANGE_ME"
  POSTGRES_DB: "mlflow"
