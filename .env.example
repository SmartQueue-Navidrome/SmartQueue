# SmartQueue Deployment Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# Node1 public IP (from terraform output, or set after provisioning)
FLOATING_IP=

# SSH key for Chameleon Cloud
SSH_KEY=~/.ssh/id_rsa_chameleon

# PostgreSQL
PG_PASSWORD=

# Chameleon S3 credentials (CHI@TACC > Identity > Application Credentials > EC2)
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Docker image tag (optional)
IMAGE_TAG=v2

# Navidrome admin credentials (used by seed_song_catalog.py)
NAVIDROME_ADMIN_USER=
NAVIDROME_ADMIN_PASSWORD=
